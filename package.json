{
  "name": "myschoolos",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev --workspace @myschoolos/web",
    "dev:api": "npm run dev --workspace @myschoolos/api",
    "dev:worker": "npm run dev --workspace @myschoolos/worker",
    "test:root-route": "node --import tsx --test apps/web/src/routes/root.render.test.tsx",
    "build": "npm run build --workspace @myschoolos/config && npm run build --workspace @myschoolos/shared && npm run build --workspace @myschoolos/observability && npm run build --workspace @myschoolos/ui && npm run build --workspace @myschoolos/db && npm run build --workspace @myschoolos/api && npm run build --workspace @myschoolos/worker && npm run build --workspace @myschoolos/web",
    "lint": "npm run lint --workspaces",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces",
    "format": "prettier . --write",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.8.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
