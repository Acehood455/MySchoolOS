// Prisma bootstrap schema for MySchoolOS.
// This is a minimal placeholder so Prisma can generate and migrate during bootstrap.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BootstrapState {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bootstrap_state")
}
