// Foundation-only Prisma schema for MySchoolOS.
// This file intentionally covers only the Foundation entity set.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum DomainType {
  SUBDOMAIN
  CUSTOM_DOMAIN
}

enum DomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  REVOKED
}

enum DomainStatus {
  PENDING
  VERIFIED
  REMAPPED
  REVOKED
  ARCHIVED
}

enum ThemeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SettingsStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum UserScope {
  SCHOOL
  PLATFORM
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
  ARCHIVED
}

enum SessionScope {
  SCHOOL
  PLATFORM
}

enum SessionStatus {
  ACTIVE
  REFRESHED
  REVOKED
  EXPIRED
}

enum RoleKey {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum RoleScope {
  PLATFORM
  TENANT
}

enum RoleStatus {
  ACTIVE
  DEPRECATED
  RETIRED
}

enum RoleAssignmentStatus {
  ACTIVE
  REVOKED
  ARCHIVED
}

enum AuditActorType {
  USER
  SYSTEM
  UNKNOWN
}

enum AuditResourceType {
  SCHOOL
  SCHOOL_DOMAIN
  SCHOOL_THEME
  SCHOOL_SETTINGS
  USER
  SESSION
  ROLE
  ROLE_ASSIGNMENT
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

model School {
  id            String      @id @default(cuid())
  schoolId      String      @unique @map("school_id")
  name          String
  slug          String?     @unique
  legalName     String?     @map("legal_name")
  description   String?
  status        SchoolStatus @default(PENDING)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  createdById   String?     @map("created_by")
  updatedById   String?     @map("updated_by")
  activatedAt   DateTime?   @map("activated_at")
  suspendedAt   DateTime?   @map("suspended_at")
  reactivatedAt DateTime?   @map("reactivated_at")
  archivedAt    DateTime?   @map("archived_at")
  metadata      Json?

  domains       SchoolDomain[]
  themes        SchoolTheme[]
  settings      SchoolSettings[]
  users         User[]
  roleAssignments RoleAssignment[]
  auditLogs     AuditLog[]

  @@index([status, createdAt])
}

model SchoolDomain {
  id                 String                   @id @default(cuid())
  schoolId           String                   @map("school_id")
  host               String
  hostType           DomainType               @map("host_type")
  verificationStatus DomainVerificationStatus @default(PENDING) @map("verification_status")
  status             DomainStatus             @default(PENDING)
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  createdById        String?                  @map("created_by")
  verifiedAt         DateTime?                @map("verified_at")
  verifiedById       String?                  @map("verified_by")
  remappedFromHost   String?                  @map("remapped_from_host")
  remappedToHost     String?                  @map("remapped_to_host")
  archivedAt         DateTime?                @map("archived_at")
  metadata           Json?

  school             School                   @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@unique([host, status])
  @@index([host])
  @@index([schoolId, status])
  @@index([schoolId, verificationStatus])
  @@index([host, verificationStatus])
}

model SchoolTheme {
  id            String      @id @default(cuid())
  schoolId      String      @map("school_id")
  version       Int         @default(1)
  logo          String?
  primaryColor  String?     @map("primary_color")
  secondaryColor String?    @map("secondary_color")
  favicon       String?
  fontFamily    String?     @map("font_family")
  brandAssets   Json?       @map("brand_assets")
  status        ThemeStatus @default(DRAFT)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  createdById   String?     @map("created_by")
  updatedById   String?     @map("updated_by")
  archivedAt    DateTime?   @map("archived_at")
  metadata      Json?

  school        School      @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@unique([schoolId, version])
  @@index([schoolId, status])
}

model SchoolSettings {
  id                     String         @id @default(cuid())
  schoolId               String         @map("school_id")
  version                Int            @default(1)
  academicPreferences    Json?          @map("academic_preferences")
  notificationPreferences Json?         @map("notification_preferences")
  operationalPreferences Json?          @map("operational_preferences")
  status                 SettingsStatus @default(DRAFT)
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  createdById            String?        @map("created_by")
  updatedById            String?        @map("updated_by")
  archivedAt             DateTime?      @map("archived_at")
  metadata               Json?

  school                 School         @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@unique([schoolId, version])
  @@index([schoolId, status])
}

model User {
  id              String     @id @default(cuid())
  scope           UserScope  @default(SCHOOL)
  schoolId        String?    @map("school_id")
  loginIdentifier String     @map("login_identifier")
  displayName     String     @map("display_name")
  authSubject     String?    @unique @map("auth_subject")
  status          UserStatus @default(INVITED)
  lastLoginAt     DateTime?  @map("last_login_at")
  invitedAt       DateTime?  @map("invited_at")
  activatedAt     DateTime?  @map("activated_at")
  suspendedAt     DateTime?  @map("suspended_at")
  deactivatedAt   DateTime?  @map("deactivated_at")
  archivedAt      DateTime?  @map("archived_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  createdById     String?    @map("created_by")
  updatedById     String?    @map("updated_by")
  metadata        Json?

  school          School?    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  sessions        Session[]
  roleAssignments  RoleAssignment[]
  auditLogs       AuditLog[] @relation("AuditActor")

  @@unique([scope, loginIdentifier])
  @@index([loginIdentifier])
  @@index([schoolId, status])
  @@index([scope, status])
}

model Session {
  id               String        @id @default(cuid())
  scope            SessionScope  @default(SCHOOL)
  schoolId         String?       @map("school_id")
  userId           String        @map("user_id")
  sessionTokenHash String        @unique @map("session_token_hash")
  status           SessionStatus @default(ACTIVE)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  lastRefreshedAt  DateTime?     @map("last_refreshed_at")
  expiresAt        DateTime      @map("expires_at")
  revokedAt        DateTime?     @map("revoked_at")
  revokedById      String?       @map("revoked_by")
  ipAddress        String?       @map("ip_address")
  userAgent        String?       @map("user_agent")
  metadata         Json?

  school           School?      @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user             User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([schoolId, userId, expiresAt])
  @@index([schoolId, status])
  @@index([status, expiresAt])
}

model Role {
  id          String    @id @default(cuid())
  roleKey     RoleKey   @unique @map("role_key")
  name        String
  description String?
  scope       RoleScope @default(TENANT)
  status      RoleStatus @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  metadata    Json?

  roleAssignments RoleAssignment[]

  @@index([scope, status])
}

model RoleAssignment {
  id          String                @id @default(cuid())
  schoolId    String                @map("school_id")
  userId      String                @map("user_id")
  roleId      String                @map("role_id")
  status      RoleAssignmentStatus  @default(ACTIVE)
  assignedAt  DateTime              @default(now()) @map("assigned_at")
  revokedAt   DateTime?             @map("revoked_at")
  revokedById String?               @map("revoked_by")
  reason      String?
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  createdById String?               @map("created_by")
  updatedById String?               @map("updated_by")
  metadata    Json?

  school      School                @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  role        Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([schoolId, userId, roleId])
  @@index([schoolId, userId, status])
  @@index([roleId, status])
}

model AuditLog {
  id            String            @id @default(cuid())
  schoolId      String?           @map("school_id")
  actorType     AuditActorType    @map("actor_type")
  actorUserId   String?           @map("actor_user_id")
  eventName     String            @map("event_name")
  resourceType  AuditResourceType @map("resource_type")
  resourceId    String?           @map("resource_id")
  severity      AuditSeverity
  outcome       AuditOutcome
  requestId     String?           @map("request_id")
  sessionId     String?           @map("session_id")
  ipAddress     String?           @map("ip_address")
  userAgent     String?           @map("user_agent")
  beforeState   Json?             @map("before_state")
  afterState    Json?             @map("after_state")
  reason        String?
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")

  actorUser     User?             @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  school        School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([eventName, createdAt])
  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId])
}
